# Base URL of the SRH-BACKEND-API (no trailing /api/v1 — the client adds it)
VITE_API_BASE_URL=http://localhost:8000

# When "true", the app uses src/api/mockClient.js (stubbed responses) instead of
# the real backend. Set to "false" once the ML models are served by the backend.
VITE_USE_MOCK=true

# Base URL of the independent Accessibility Services microservice
# (accessibility-service/). Leave EMPTY to use built-in fallbacks (browser Web
# Speech for TTS, authored alt text, no simplify post-processing). Set it to
# enable real TTS / alt-text / simplified-language, e.g. http://localhost:8080
VITE_ACCESSIBILITY_API_URL=
